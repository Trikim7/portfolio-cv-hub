# ─── Backend local .env example ────────────────────────────────
# For running FastAPI locally WITHOUT docker-compose.
# Copy to backend/.env and edit values.

# Database (local dev Postgres on host machine)
DATABASE_URL=postgresql+psycopg2://cvhub:cvhub_dev_pw@localhost:5432/portfolio_cv_hub

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# OAuth providers (Phase 2 - social auth)
# Redirect URIs: {OAUTH_REDIRECT_BASE_URL}/api/auth/oauth/{google|github}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
