# ─── Root-level .env for docker-compose ────────────────────────
# Copy to .env and fill in values. Do NOT commit .env with real secrets.

# Postgres (used by the `postgres` service and composed into DATABASE_URL)
POSTGRES_USER=cvhub
POSTGRES_PASSWORD=cvhub_dev_pw
POSTGRES_DB=portfolio_cv_hub
# Host port for Postgres; we default to 5433 to avoid colliding with a local
# Postgres already bound to 5432 on the host machine.
POSTGRES_HOST_PORT=5433

# Backend
DATABASE_URL=postgresql+psycopg2://cvhub:cvhub_dev_pw@postgres:5432/portfolio_cv_hub
SECRET_KEY=change-me-in-production

# OAuth providers (Phase 2 - social auth). Leave blank if not testing locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
