# ─── Root-level .env for docker-compose ────────────────────────
# Copy this file to .env at the project root, then fill in real values.
# ⚠️  NEVER commit .env with real secrets to git.

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=cvhub
POSTGRES_PASSWORD=cvhub_dev_pw
POSTGRES_DB=portfolio_cv_hub
# Host port (change if 5433 is already taken on your machine)
POSTGRES_HOST_PORT=5433

# ─── Backend ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://cvhub:cvhub_dev_pw@postgres:5432/portfolio_cv_hub
# Generate a strong random key for production:  openssl rand -hex 32
SECRET_KEY=change-me-in-production

# ─── OAuth providers (Phase 2 — social auth) ─────────────────────
# Leave blank if you are not testing social login locally.
# Callback URIs: {OAUTH_REDIRECT_BASE_URL}/api/auth/oauth/{google|github}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ─── Cloudinary (avatar, logo & CV file uploads) ─────────────────
# Sign up free at https://cloudinary.com → Dashboard → copy the 3 values below.
# Leave blank to fall back to local-disk storage (dev only — not deploy-safe).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
